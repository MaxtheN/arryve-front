# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Public booking URL for the Google Workspace / Google Calendar demo scheduler.
# If omitted, the site falls back to opening a Google Calendar invite draft addressed to contact@tryarryve.com.
VITE_BOOK_DEMO_URL="https://calendar.app.google/eo9uCycR6vUZLAau8"

# Automation backend for the Gemini Live voice demo's tool grounding.
# When unset, the demo still runs (grounded on the system prompt KB only).
# When set, Arvy can call search_availability / rate_details / read_folio /
# lost_found_search / search_by_phone against the HotelKey training tenant
# via our automation service. Requests are HMAC-signed with the shared
# secret below, and the automation service verifies the `x-arryve-demo-*`
# headers before executing the flow.
AUTOMATION_URL=""
AUTOMATION_TOOL_SECRET=""

# ─────────────────────────────────────────────────────────────────────────
# Conversion tracking — /demo-request lead page (Meta + Google Ads)
#
# EVERYTHING here is optional and no-ops when unset: the page deploys and
# leads still flow to Postgres with all of these blank. Fill them in and
# redeploy to switch tracking on — no code change.

# Meta Pixel ID (Events Manager → Data sources → your dataset → Settings).
# NOT from an ad campaign. Same numeric id for browser + server.
VITE_META_PIXEL_ID=""
META_PIXEL_ID=""
# Conversions API access token (same dataset → Settings → Conversions API →
# Generate access token). SECRET — server-only, never VITE_-prefixed.
META_CAPI_TOKEN=""
# Optional: defaults to v21.0.
META_CAPI_GRAPH_VERSION=""
# Optional: set to a Test Events code to see CAPI events in Meta's Test
# Events tab. Leave blank in production.
META_TEST_EVENT_CODE=""

# Google tag / Google Ads (Goals → Conversions, NOT the campaign builder).
# The tag id is already known:
VITE_GOOGLE_ADS_ID="AW-18164301008"
# Conversion LABELS — created per conversion action in Google Ads
# (Goals → Conversions → + New conversion action → Website). Until these
# are set, the Google tag still does remarketing + page views but no
# conversion is counted.
VITE_GOOGLE_ADS_LEAD_LABEL=""
VITE_GOOGLE_ADS_SCHEDULE_LABEL=""
# Optional GA4 measurement id (GA4 Admin → Data streams). When set, the
# lead also fires GA4 generate_lead / schedule (importable into Ads).
VITE_GA_MEASUREMENT_ID=""
# Server-side Ads conversion is a v1 stub; leave false.
GOOGLE_ADS_CONVERSION_ENABLED="false"

# Shared HMAC secret used to sign lead forwards to the dashboard-api.
# MUST be byte-identical to dashboard-api + arryve-dashboard. Already set
# for the existing session pipeline — reused unchanged.
DASHBOARD_HMAC_SECRET=""
# Local end-to-end only: point lead forwarding at a local dashboard-api.
# Prod leaves this unset (uses https://api.tryarryve.com/dashboard).
DASHBOARD_BASE=""
